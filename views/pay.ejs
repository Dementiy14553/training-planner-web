<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Оплата подписки</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .payment-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.35);
            width: 100%;
            max-width: 480px;
            overflow: hidden;
        }
        .header {
            background: linear-gradient(to right, #4CAF50, #2E7D32);
            color: white;
            padding: 25px;
            text-align: center;
        }
        .content {
            padding: 35px 30px;
            text-align: center;
        }
        .price {
            font-size: 58px;
            font-weight: bold;
            color: #1976D2;
            margin: 15px 0 5px;
        }
        .subtitle {
            color: #666;
            font-size: 18px;
        }
        .methods {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin: 25px 0;
        }
        .method {
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 17px;
        }
        .method:hover, .method.selected {
            border-color: #4CAF50;
            background: #f0fff0;
        }
        .qr-container {
            margin: 30px 0;
            padding: 25px;
            background: #f9f9f9;
            border-radius: 12px;
        }
        #qrcode {
            margin: 15px auto;
            width: 200px;
            height: 200px;
            background: white;
            border: 3px dashed #4CAF50;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            color: #555;
            text-align: center;
            line-height: 1.5;
        }
        button {
            background: #4CAF50;
            color: white;
            border: none;
            padding: 16px;
            font-size: 19px;
            border-radius: 12px;
            cursor: pointer;
            width: 100%;
            margin-top: 15px;
        }
        .back-btn {
            background: #757575;
        }
    </style>
</head>
<body>
    <div class="payment-card">
        <div class="header">
            <h2>Оплата подписки</h2>
        </div>
        <div class="content">
            <p style="font-size:18px;">Полный доступ к приложению</p>
            <div class="price">1 ₽</div>
            <p class="subtitle">за 30 дней</p>

            <div class="methods">
                <div class="method selected" onclick="selectMethod(this)">💳 Банковская карта</div>
                <div class="method" onclick="selectMethod(this)">📱 СБП (быстрая оплата)</div>
                <div class="method" onclick="selectMethod(this)">💰 ЮMoney</div>
            </div>

            <div class="qr-container">
                <p style="margin-bottom:12px; color:#555;">Или отсканируй QR-код с телефона:</p>
                <div id="qrcode">
                    QR-код для оплаты<br>
                    <strong>1 ₽</strong>
                </div>
            </div>

            <button onclick="makePayment()">Оплатить 1 ₽</button>
            <button class="back-btn" onclick="goBack()">Отмена</button>
        </div>
    </div>

    <script>
        function selectMethod(el) {
            document.querySelectorAll('.method').forEach(m => m.classList.remove('selected'));
            el.classList.add('selected');
        }

        function makePayment() {
            const token = localStorage.getItem('authToken');
            fetch(`/pay-success?token=${token}`, { 
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert('✅ Оплата прошла успешно!\nПодписка активирована на 30 дней.');
                    window.location.href = `/dashboard?token=${token}`;
                }
            })
            .catch(() => alert('Ошибка оплаты'));
        }

        function goBack() {
            const token = localStorage.getItem('authToken');
            window.location.href = `/subscription-expired?token=${token}`;
        }
    </script>
</body>
</html>