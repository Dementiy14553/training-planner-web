<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Создать тренировку</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');
        
        body {
            font-family: 'Roboto', sans-serif;
            background: #f5f5f5;
            margin: 0;
            padding: 0;
        }
        .header {
            background: #1976D2;
            color: white;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .container {
            padding: 20px;
            max-width: 900px;
            margin: 0 auto;
        }
        input[type="text"] {
            width: 100%;
            padding: 12px;
            margin: 8px 0;
            border: 1px solid #ccc;
            border-radius: 8px;
            font-size: 16px;
        }
        .exercise-item {
            background: white;
            padding: 15px;
            margin: 12px 0;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: flex;
            gap: 10px;
            align-items: center;
        }
        .exercise-item input {
            flex: 1;
        }
        .btn-add {
            background: #4CAF50;
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            margin: 15px 0;
        }
        .btn-save {
            background: #1976D2;
            color: white;
            border: none;
            padding: 14px 30px;
            border-radius: 8px;
            font-size: 18px;
            cursor: pointer;
        }
        .btn-delete {
            background: #f44336;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 6px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="header">
        <h2>Создать новую тренировку</h2>
        <button onclick="goBack()" style="background:#1976D2; color:white; border:none; padding:12px 25px; border-radius:8px; cursor:pointer;">← Назад в меню</button>
    </div>

    <div class="container">
        <input type="text" id="workoutName" placeholder="Название тренировки (например: Силовая верх)" required>

        <h3>Упражнения</h3>
        <div id="exercisesList"></div>

        <button class="btn-add" onclick="addExercise()">+ Добавить упражнение</button>
        <br><br>
        <button class="btn-save" onclick="saveWorkout()">Сохранить тренировку</button>
    </div>

    <script>
        let exerciseCount = 0;

        function addExercise() {
            exerciseCount++;
            const div = document.createElement('div');
            div.className = 'exercise-item';
            div.innerHTML = `
                <input type="text" placeholder="Название упражнения" id="ex-name-${exerciseCount}">
                <input type="text" placeholder="Повторения / время / детали" id="ex-details-${exerciseCount}">
                <button class="btn-delete" onclick="this.parentElement.remove()">Удалить</button>
            `;
            document.getElementById('exercisesList').appendChild(div);
        }

        function goBack() {
            const token = localStorage.getItem('authToken');
            window.location.href = token ? `/dashboard?token=${token}` : '/';
        }

        async function saveWorkout() {
            const name = document.getElementById('workoutName').value.trim();
            if (!name) {
                alert('Введите название тренировки!');
                return;
            }

            const exercises = [];
            document.querySelectorAll('.exercise-item').forEach(item => {
                const nameInput = item.querySelector('input:nth-child(1)');
                const detailsInput = item.querySelector('input:nth-child(2)');
                if (nameInput && nameInput.value.trim()) {
                    exercises.push({
                        name: nameInput.value.trim(),
                        details: detailsInput ? detailsInput.value.trim() : ''
                    });
                }
            });

            if (exercises.length === 0) {
                alert('Добавьте хотя бы одно упражнение!');
                return;
            }

            try {
                const token = localStorage.getItem('authToken');
                const res = await fetch('/create-workout?token=' + token, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, exercises })
                });

                const data = await res.json();

                if (res.ok && data.success) {
                    alert('Тренировка успешно сохранена!');
                    goBack();                    // Возвращаемся на дашборд
                } else {
                    alert(data.error || 'Ошибка при сохранении');
                }
            } catch (err) {
                console.error(err);
                alert('Ошибка соединения с сервером');
            }
        }

        // Добавляем одно упражнение по умолчанию
        window.onload = () => {
            addExercise();
        };

        function goBack() {
    const token = localStorage.getItem('authToken');
    window.location.href = token ? `/dashboard?token=${token}` : '/';
}

    </script>
</body>
</html>