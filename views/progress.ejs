<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Мой прогресс</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: Arial, sans-serif; background: #f0f2f5; margin: 0; }
        .header {
            background: #1976D2; color: white; padding: 18px 25px;
            display: flex; justify-content: space-between; align-items: center;
        }
        .container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 25px;
            display: flex;
            gap: 40px;
            flex-wrap: wrap;
        }
        .left-panel, .right-panel {
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .left-panel { flex: 1; min-width: 320px; }
        .right-panel { flex: 2; min-width: 500px; }
        input[type="date"], input[type="number"] {
            width: 100%;
            padding: 12px;
            font-size: 16px;
            border: 1px solid #ccc;
            border-radius: 8px;
            margin-bottom: 12px;
        }
        button {
            background: #4CAF50;
            color: white;
            border: none;
            padding: 12px 30px;
            font-size: 16px;
            border-radius: 8px;
            cursor: pointer;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }
        .btn-back {
            background: #1976D2;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="header">
        <h2>Мой прогресс (вес)</h2>
        <button class="btn-back" onclick="goBack()">← Назад в меню</button>
    </div>

    <div class="container">
        <!-- Левая панель -->
        <div class="left-panel">
            <h3>Добавить запись веса</h3>
            
            <label>Дата:</label>
            <input type="date" id="dateInput">

            <label>Вес (кг):</label>
            <input type="number" id="weightInput" step="0.1" placeholder="Например: 75.5">

            <button onclick="addWeight()">Добавить запись</button>

            <h3 style="margin-top:40px">История измерений</h3>
            <table id="historyTable">
                <thead>
                    <tr><th>Дата</th><th>Вес (кг)</th><th>Действие</th></tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <!-- Правая панель -->
        <div class="right-panel">
            <h3>Динамика изменения веса</h3>
            <canvas id="weightChart" height="380"></canvas>
        </div>
    </div>

    <script>
        const token = new URLSearchParams(window.location.search).get('token');
        let chart;

        async function loadProgress() {
            try {
                const res = await fetch(`/api/progress?token=${token}`);
                const entries = await res.json();

                // Таблица
                const tbody = document.querySelector('#historyTable tbody');
                tbody.innerHTML = '';
                entries.forEach(entry => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td>${entry.date}</td>
                        <td>${entry.weight}</td>
                        <td><button onclick="deleteWeight(${entry.id})" style="background:#f44336;color:white;border:none;padding:5px 12px;border-radius:4px;cursor:pointer">Удалить</button></td>
                    `;
                    tbody.appendChild(tr);
                });

                // График — точно как в старой версии
                const ctx = document.getElementById('weightChart').getContext('2d');
                if (chart) chart.destroy();

                chart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: entries.map(e => e.date),
                        datasets: [{
                            label: 'Вес (кг)',
                            data: entries.map(e => e.weight),
                            borderColor: '#1976D2',
                            backgroundColor: 'rgba(25, 118, 210, 0.15)',
                            tension: 0.3,
                            borderWidth: 3,
                            pointRadius: 5
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: {
                            y: { beginAtZero: false }
                        }
                    }
                });
            } catch (e) {
                console.error(e);
            }
        }

        async function addWeight() {
            const weight = parseFloat(document.getElementById('weightInput').value);
            const date = document.getElementById('dateInput').value;

            if (!weight || !date) {
                alert('Введите вес и выберите дату!');
                return;
            }

            try {
                const res = await fetch(`/progress?token=${token}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ weight, date })
                });

                if (res.ok) {
                    alert('Вес успешно добавлен!');
                    document.getElementById('weightInput').value = '';
                    loadProgress();          // ← как в твоей старой версии
                } else {
                    alert('Ошибка при добавлении веса');
                }
            } catch (e) {
                alert('Ошибка соединения');
            }
        }

        async function deleteWeight(id) {
            if (!confirm('Удалить эту запись?')) return;

            try {
                await fetch(`/api/progress/${id}?token=${token}`, { method: 'DELETE' });
                loadProgress();
            } catch (e) {
                alert('Ошибка удаления');
            }
        }

        function goBack() {
            window.location.href = `/dashboard?token=${token}`;
        }

        // Устанавливаем сегодняшнюю дату и загружаем данные
        window.onload = () => {
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('dateInput').value = today;
            loadProgress();
        };
    </script>
</body>
</html>